---
import ParcoursPage from '../../components/ParcoursPage.astro';
---

<ParcoursPage
  currentPath="/parcours/bonheur"
  title="Parcours : Être Plus Heureux"
  description="Ton parcours guidé vers un bonheur durable et authentique"
  hero={{
    title: '😊 Être plus heureux',
    tagline:
      'Découvre les clés scientifiques du bonheur et apprends à cultiver le bien-être au quotidien',
    actions: [{ text: 'Commencer le premier module', link: '/bonheur/les-hormones-du-bonheur', variant: 'primary' }],
  }}
  parcourId="bonheur"
  modules={[
    { title: 'Les hormones du bonheur', link: '/bonheur/les-hormones-du-bonheur' },
    { title: 'Cultiver la gratitude', link: '/psy/emotions/gratitude' },
    { title: 'Le moment présent', link: '/bonheur/choyer-le-moment-present' },
    { title: 'Équilibre mental', link: '/psy/equilibre/equilibre-mental' },
    { title: 'Cultiver le bonheur', link: '/bonheur/cultiver-le-bonheur' },
    { title: 'Bonheur durable', link: '/bonheur/bonheur-durable' },
  ]}
  intro="À l'issue de ce parcours, tu comprendras pourquoi le bonheur se construit — et tu auras des outils concrets pour le faire. Pas de promesses magiques : de la science, des pratiques testées, et un chemin qui te ressemble."
  steps={[
    {
      title: 'Étape 1 — Comprendre le bonheur (la science derrière)',
      body: "Le bonheur n'est pas un hasard. Dopamine, sérotonine, ocytocine, endorphines — quatre molécules qui jouent un rôle clé dans ton bien-être. Comprendre leur fonctionnement, c'est apprendre à les activer volontairement.",
      links: [
        { href: '/bonheur/les-hormones-du-bonheur', text: 'Les hormones du bonheur' },
        { href: '/bonheur/bonheur-durable', text: 'La science du bonheur durable' },
      ],
    },
    {
      title: 'Étape 2 — Cultiver les émotions positives',
      body: "La gratitude, la joie, la sérénité ne sont pas des états réservés à quelques chanceux. Ce sont des muscles que tu peux entraîner. Cette étape t'apprend à reconnaître et amplifier les émotions qui nourrissent ton bonheur.",
      links: [
        { href: '/psy/emotions/gratitude', text: 'La gratitude : comment la cultiver' },
        { href: '/psy/emotions/joie', text: 'La joie, une émotion à apprivoiser' },
        { href: '/psy/emotions/serenite', text: 'La sérénité au quotidien' },
      ],
    },
    {
      title: 'Étape 3 — Construire des habitudes qui durent',
      body: "Le bonheur s'ancre dans le quotidien, pas dans les grands événements. Cette étape te guide pour créer des habitudes simples, cohérentes et alignées avec ce qui compte vraiment pour toi.",
      links: [
        { href: '/bonheur/cultiver-le-bonheur', text: 'Cultiver le bonheur au jour le jour' },
        { href: '/objectifs/changer-ses-habitudes', text: 'Changer ses habitudes durablement' },
      ],
    },
    {
      title: 'Étape 4 — Trouver ton équilibre intérieur',
      body: "L'harmonie entre tes besoins physiques, émotionnels et mentaux est le socle d'un bien-être profond. Cette étape t'aide à identifier ce qui te déséquilibre — et à y remédier.",
      links: [
        { href: '/harmonie/homeostasie', text: "L'homéostasie ou l'art de l'équilibre" },
        { href: '/harmonie/equilibre-vie', text: 'Équilibre vie pro / vie perso' },
      ],
    },
    {
      title: 'Étape 5 — Vivre pleinement le présent',
      body: `Le bonheur existe maintenant, pas "quand j'aurai réussi". Apprends à savourer l'instant, à réduire le bruit mental et à te reconnecter à ce qui est là.`,
      links: [
        { href: '/bonheur/choyer-le-moment-present', text: 'Choyer le moment présent' },
        { href: '/psy/solution/mindfulness', text: 'La pleine conscience (mindfulness)' },
      ],
    },
  ]}
  resources={[
    { href: '/bonheur/', text: 'Explorer tout le cluster bonheur' },
    { href: '/bonheur/cultiver-le-bonheur', text: 'Cultiver le bonheur au quotidien' },
    { href: '/psy/emotions/gratitude', text: 'La pratique de la gratitude' },
    { href: '/bonheur/les-hormones-du-bonheur', text: 'Comprendre les hormones du bonheur' },
    { href: '/psy/emotions/kit-sos-emotions', text: 'Le kit SOS émotions' },
    { href: '/harmonie/meditation', text: 'La méditation, par où commencer' },
    { href: '/psy/solution/resilience', text: 'La résilience : rebondir après les épreuves' },
  ]}
  closing="Tu as tout ce qu'il faut pour être heureux. Ce parcours t'aide juste à le retrouver."
/>
