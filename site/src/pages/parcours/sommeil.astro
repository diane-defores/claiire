---
import ParcoursPage from '../../components/ParcoursPage.astro';
---

<ParcoursPage
  currentPath="/parcours/sommeil"
  title="Parcours : Améliorer Ton Sommeil"
  description="Restaure un sommeil réparateur pour une vie plus énergique"
  hero={{
    title: '😴 Améliorer ton sommeil',
    tagline: 'Restaure un sommeil réparateur pour une vie plus énergique',
    actions: [{ text: 'Commencer le premier module', link: '/sommeil/', variant: 'primary' }],
  }}
  parcourId="sommeil"
  modules={[
    { title: 'Comprendre le sommeil', link: '/sommeil/' },
    { title: 'Les cycles du sommeil', link: '/sommeil/cycles' },
    { title: 'Hygiène du sommeil', link: '/sommeil/hygiene' },
    { title: 'Dette de sommeil', link: '/sommeil/dette' },
    { title: 'Nutrition et sommeil', link: '/systeme-digestif/nutrition/sommeil-nutriments' },
    { title: 'Lumière et mélatonine', link: '/systeme-hormonal/melatonine' },
  ]}
  intro="Ce parcours te donne les clés pour comprendre ton sommeil, identifier ce qui le perturbe et retrouver des nuits vraiment réparatrices. Fini de te réveiller épuisé : on reconstruit tout, étape par étape."
  steps={[
    {
      title: 'Étape 1 — Comprendre les cycles du sommeil',
      body: "Le sommeil n'est pas uniforme. Chaque nuit, ton cerveau traverse des cycles de 90 minutes — sommeil léger, profond, paradoxal. Comprendre cette architecture, c'est arrêter de se battre contre sa biologie.",
