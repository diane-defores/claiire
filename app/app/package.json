{
  "name": "app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "projects": [
      {
        "displayName": "unit",
        "preset": "ts-jest",
        "testEnvironment": "node",
        "testMatch": [
          "**/engine/**/*.test.ts"
        ],
        "moduleNameMapper": {
          "^@/(.*)$": "<rootDir>/$1"
        }
      },
      {
        "displayName": "react-native",
        "preset": "jest-expo",
        "testMatch": [
          "**/*.test.tsx",
          "**/components/**/*.test.ts"
        ],
        "moduleNameMapper": {
          "^@/(.*)$": "<rootDir>/$1"
        },
        "transformIgnorePatterns": [
          "/node_modules/(?!(.pnpm|react-native|@react-native|@react-native-community|expo|@expo|react-navigation|@react-navigation|convex|zustand))"
        ]
      }
    ]
  },
  "dependencies": {
    "@clerk/expo": "^3.0.1",
    "@react-navigation/native": "^7.1.28",
    "convex": "^1.17.4",
    "expo": "~55.0.5",
    "expo-constants": "~55.0.7",
    "expo-device": "^55.0.9",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-notifications": "^55.0.12",
    "expo-router": "~55.0.4",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-web-browser": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "jest": "^30.2.0",
    "jest-expo": "^55.0.9",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "private": true
}
