---
interface Props {
  parcourId: string;
  modules: Array<{ title: string; link: string }>;
}

const { parcourId, modules } = Astro.props;
---

<div class="parcour-progress-widget" data-parcour-id={parcourId}>
  <div class="progress-header">
    <h3>Ta progression</h3>
    <span class="progress-percentage">0%</span>
  </div>

  <div class="progress-bar">
    <div class="progress-fill" style="width: 0%"></div>
  </div>

  <ul class="module-list">
    {modules.map((module, index) => (
      <li class="module-item" data-module-index={index}>
        <input
          type="checkbox"
          id={`module-${parcourId}-${index}`}
          class="module-checkbox"
        />
        <label for={`module-${parcourId}-${index}`}>
          <span class="checkbox-custom"></span>
          <span class="module-title">{module.title}</span>
        </label>
        <a href={module.link} class="module-arrow" aria-label={`Accéder à ${module.title}`}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </li>
    ))}
  </ul>

  <button class="reset-progress">Réinitialiser la progression</button>
</div>

<script>
  import { initParcourTracker } from '../scripts/parcours-tracker.js';

  document.addEventListener('DOMContentLoaded', () => {
    initParcourTracker();
  });
</script>

<style>
  .parcour-progress-widget {
    background: linear-gradient(180deg, var(--site-surface-strong) 0%, var(--site-surface-muted) 100%);
    border: 1px solid var(--site-border);
    border-radius: 1rem;
    box-shadow: var(--shadow-soft);
    padding: 1.5rem;
    margin: 2rem 0;
  }

  .progress-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .progress-header h3 {
    margin: 0;
    font-size: 1.25rem;
  }

  .progress-percentage {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--sl-color-accent);
    padding: 0.2rem 0.75rem;
    border-radius: 999px;
    background: var(--site-accent-soft);
  }

  .progress-bar {
    height: 8px;
    background: var(--sl-color-gray-5);
    border-radius: 999px;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--site-highlight) 0%, var(--sl-color-accent) 100%);
    border-radius: inherit;
    transition: width 0.3s ease;
  }

  .module-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .module-item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    padding: 0.9rem 1rem;
    border: 1px solid var(--site-border);
    border-radius: 0.9rem;
    background: var(--site-surface);
    overflow: hidden;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease,
      background-color 0.18s ease;
  }

  .module-item::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 0.3rem;
    background: linear-gradient(180deg, var(--site-highlight) 0%, var(--sl-color-accent) 100%);
    opacity: 0.15;
    transition: opacity 0.18s ease;
  }

  .module-item:hover {
    border-color: var(--site-accent);
    box-shadow: var(--shadow-soft);
    transform: translateY(-1px);
  }

  .module-item:hover::before {
    opacity: 0.4;
  }

  .module-item[data-complete='true'] {
    border-color: var(--site-accent);
    background: linear-gradient(180deg, var(--site-accent-soft) 0%, var(--site-surface-strong) 100%);
    box-shadow: var(--shadow-soft);
  }

  .module-item[data-complete='true']::before {
    opacity: 1;
  }

  .module-item label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 0;
    cursor: pointer;
  }

  .module-checkbox {
    position: absolute;
    opacity: 0;
    width: 20px;
    height: 20px;
    cursor: pointer;
  }

  .module-checkbox:focus-visible + label .checkbox-custom {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .checkbox-custom {
    width: 1.35rem;
    height: 1.35rem;
    border: 2px solid var(--sl-color-gray-4);
    border-radius: 0.45rem;
    position: relative;
    flex-shrink: 0;
    background: linear-gradient(180deg, var(--site-surface-strong) 0%, var(--site-surface-muted) 100%);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
    transition:
      transform 0.18s ease,
      background-color 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .module-item:hover .checkbox-custom {
    border-color: var(--site-accent);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      var(--shadow-soft);
    transform: translateY(-1px);
  }

  .module-checkbox:checked + label .checkbox-custom {
    background: linear-gradient(180deg, var(--site-highlight) 0%, var(--sl-color-accent) 100%);
    border-color: var(--sl-color-accent);
    box-shadow: var(--site-primary-shadow);
    transform: scale(1.04);
    animation: checkbox-pop 0.24s ease-out;
  }

  .module-checkbox:checked + label .checkbox-custom::after {
    content: '';
    position: absolute;
    width: 0.34rem;
    height: 0.68rem;
    border-right: 2px solid white;
    border-bottom: 2px solid white;
    top: 45%;
    left: 50%;
    transform: translate(-50%, -58%) rotate(45deg);
  }

  .module-checkbox:checked + label .module-title {
    text-decoration: line-through;
    opacity: 0.6;
  }

  .module-title {
    font-weight: 600;
    transition: color 0.18s ease;
  }

  .module-item[data-complete='true'] .module-title {
    color: var(--site-accent-strong);
  }

  .module-arrow {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    color: var(--sl-color-gray-3);
    transition:
      color 0.2s ease,
      transform 0.2s ease;
  }

  .module-arrow:hover {
    color: var(--sl-color-accent);
    transform: translateX(2px);
  }

  .module-item[data-complete='true'] .module-arrow {
    color: var(--sl-color-accent);
  }

  .reset-progress {
    margin-top: 1rem;
    padding: 0.65rem 1rem;
    background: var(--site-surface);
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 999px;
    cursor: pointer;
    font-size: 0.875rem;
    color: var(--sl-color-text);
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .reset-progress:hover {
    background: var(--sl-color-gray-5);
    transform: translateY(-1px);
  }

  @keyframes checkbox-pop {
    0% {
      transform: scale(0.9);
    }

    70% {
      transform: scale(1.08);
    }

    100% {
      transform: scale(1.04);
    }
  }
</style>
