  {
    label: 'Journal des pensées',
    detail: 'Le coeur pratique du module.',
  },
  {
    label: 'Repères cognitifs',
    detail: 'Beck, Ellis, Young, Neff.',
  },
  {
    label: 'Parcours victimes',
